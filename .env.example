# ─── Base de datos ─────────────────────────────────────────────────────────────
# Dev local: apuntar a la BD de staging de Supabase (tiene datos mockeados).
# Formato Supabase: postgresql+psycopg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# El connection string lo encontrás en: Supabase → proyecto → Settings → Database → Connection string → URI
# Elegí "Transaction mode" (puerto 6543) para Celery workers, "Session mode" (5432) para la API.
DATABASE_URL=postgresql+psycopg://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# ─── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Flags de desarrollo ───────────────────────────────────────────────────────
# Con USE_MOCKS=true los servicios externos (Clerk JWT, webhooks, R2, MP, etc.)
# se mockean y el sistema funciona sin credenciales reales.
USE_MOCKS=true

# ─── LLM ───────────────────────────────────────────────────────────────────────
# Cambiar el provider sin tocar código: solo actualizar LLM_MODEL.
# Ejemplos: gemini/gemini-2.0-flash · openai/gpt-4o · anthropic/claude-3-5-sonnet
LLM_MODEL=gemini/gemini-2.0-flash
GEMINI_API_KEY=

# ─── Langfuse (observabilidad LLM) ────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ─── Clerk (autenticación) ────────────────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_JWKS_URL=https://YOUR_CLERK_DOMAIN/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=

# ─── Cloudflare R2 (storage) ──────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vigi-snapshots
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# ─── Apify (job postings) ─────────────────────────────────────────────────────
APIFY_TOKEN=

# ─── MercadoLibre (API oficial) ───────────────────────────────────────────────
ML_CLIENT_ID=
ML_CLIENT_SECRET=

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Twilio (WhatsApp) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Mercado Pago (pagos) ─────────────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ─── URLs de la aplicación ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

# ─── General ──────────────────────────────────────────────────────────────────
TIMEZONE=America/Argentina/Buenos_Aires
